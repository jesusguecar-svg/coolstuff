# ============================================================
# Polybot Configuration -- copy to .env and fill in values
# ============================================================

# ── Auth (REQUIRED) ─────────────────────────────────────────
# Your EOA private key (hex, with or without 0x prefix).
# NEVER share or commit this value.
PRIVATE_KEY=

# Your Polymarket wallet address (receives collateral for trading).
FUNDER_ADDRESS=

# Signature type: 0 = EOA (default). Do not change unless you know why.
SIGNATURE_TYPE=0

# ── Mode / Safety ───────────────────────────────────────────
# paper  = simulated fills, log only
# shadow = observe real markets, compute signals, but NO orders
# live   = real orders (requires DRY_RUN=false to actually send)
MODE=paper

# Extra safety: even in live mode, DRY_RUN=true prints payloads
# without sending. Set to false ONLY when you're ready.
DRY_RUN=true

# ── Budget / Risk ───────────────────────────────────────────
MAX_BET_USD=1.00
DAILY_BUDGET_USD=5.00
MAX_OPEN_ORDERS=3

# ── Strategy: Underdog ──────────────────────────────────────
FAVORITE_MIN_PRICE=0.75
UNDERDOG_MAX_PRICE=0.25

# ── Strategy: Arbitrage ─────────────────────────────────────
MIN_ARB_EDGE=0.01

# ── Market Filters ──────────────────────────────────────────
MIN_LIQUIDITY=1000
MIN_VOLUME=1000
MAX_SPREAD=0.05
MAX_SLIPPAGE=0.05

# ── Networking ──────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=15

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────
# DB_PATH=polybot.db

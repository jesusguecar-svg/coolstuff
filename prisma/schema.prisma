generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum EquivalenceType {
  EQUIVALENT
  ANALOGOUS
  NO_DIRECT_EQUIVALENT
}

enum SourceType {
  CASE
  STATUTE
  RESTATEMENT
  UCC
  MPC
  CODE_ARTICLE
  JURISPRUDENCE
  DOCTRINE
  OTHER
}

enum ConceptSide {
  US
  VE
}

enum QuizType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  ISSUE_SPOTTER
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  role         UserRole          @default(USER)
  createdAt    DateTime          @default(now())
  sessions     Session[]
  progress     ProgressConcept[]
  stats        UserStat?
  savedConcepts SavedConcept[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model UserStat {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp         Int      @default(0)
  streak     Int      @default(0)
  lastStudyDate DateTime?
  updatedAt  DateTime @updatedAt
}

model Subject {
  id       String    @id @default(cuid())
  slug     String    @unique
  nameEn   String
  nameEs   String
  concepts Concept[]
}

model Concept {
  id        String              @id @default(cuid())
  globalId  String              @unique
  subjectId String
  subject   Subject             @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  slug      String              @unique
  tags      String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  us        ConceptUS?
  ve        ConceptVE?
  mapping   Mapping?
  example   Example?
  sourceLinks ConceptSourceLink[]
  flashcards Flashcard[]
  quizItems QuizItem[]
  progress   ProgressConcept[]
  savedBy    SavedConcept[]
}

model ConceptUS {
  id                String   @id @default(cuid())
  conceptId         String   @unique
  concept           Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  titleEn           String
  definitionEn      String
  jurisdictionScope String
  notes             String?
}

model ConceptVE {
  id           String   @id @default(cuid())
  conceptId    String   @unique
  concept      Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  titleEs      String
  definitionEs String
  notes        String?
}

model Mapping {
  id               String          @id @default(cuid())
  conceptId        String          @unique
  concept          Concept         @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  equivalenceType  EquivalenceType
  rationale        String
  differencesJson  String
  pitfallsJson     String
}

model Example {
  id         String  @id @default(cuid())
  conceptId  String  @unique
  concept    Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  scenarioEn String
  scenarioEs String
}

model Source {
  id           String              @id @default(cuid())
  sourceType   SourceType
  title        String
  citation     String
  url          String?
  jurisdiction String?
  court        String?
  year         Int?
  extraJson    String
  links        ConceptSourceLink[]
}

model ConceptSourceLink {
  id        String      @id @default(cuid())
  conceptId String
  side      ConceptSide
  sourceId  String
  summary   String
  pinToTop  Boolean     @default(false)
  concept   Concept     @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  source    Source      @relation(fields: [sourceId], references: [id], onDelete: Cascade)
}

model Flashcard {
  id        String  @id @default(cuid())
  conceptId String
  concept   Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  front     String
  back      String
  lang      String
}

model QuizItem {
  id          String   @id @default(cuid())
  conceptId   String
  concept     Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  type        QuizType
  prompt      String
  optionsJson String
  answerJson  String
  explanation String
  difficulty  Int      @default(1)
}

model Phrase {
  id                 String          @id @default(cuid())
  phraseEn           String
  phraseEs           String
  literalTranslation String?
  explanation        String
  contextTagsJson    String
  authorityRefs      String?
  examples           PhraseExample[]
}

model PhraseExample {
  id         String @id @default(cuid())
  phraseId   String
  phrase     Phrase @relation(fields: [phraseId], references: [id], onDelete: Cascade)
  sentenceEn String
  sentenceEs String
}

model ProgressConcept {
  id           String   @id @default(cuid())
  userId       String
  conceptId    String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept      Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  mastery      Int      @default(0)
  lastStudiedAt DateTime?
  nextReviewAt DateTime?
  lapseCount   Int      @default(0)

  @@unique([userId, conceptId])
}

model SavedConcept {
  id        String   @id @default(cuid())
  userId    String
  conceptId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  concept   Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([userId, conceptId])
}
